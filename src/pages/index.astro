---
import Layout from "../layouts/Layout.astro";
import BackgroundBlobs from "../components/BackgroundBlobs.astro";
import HomeSection from "../components/HomeSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import FormationSection from "../components/FormationSection.astro";
import ContactSection from "../components/ContactSection.astro";
import { l_projects } from "../data/projects";
---

<Layout title="Tristan Delthil — Développeur Full Stack">
  <BackgroundBlobs />
  <HomeSection />
  <AboutSection />
  <ProjectsSection l_projects={l_projects} />
  <FormationSection />
  <ContactSection />

  <!-- Footer minimal -->
  <footer class="footer">
    <p>© {new Date().getFullYear()} Tristan Delthil</p>
    <p>Fait avec ☕ à Toulouse</p>
  </footer>
</Layout>

<style>
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
    color: var(--text-faint);
  }

  @media (max-width: 640px) {
    .footer {
      flex-direction: column;
      gap: 0.25rem;
      text-align: center;
    }
  }
</style>
