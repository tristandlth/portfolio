---
import type { Project } from "../data/projects";

interface Props {
  l_projects: Project[];
}

const { l_projects } = Astro.props;
---

<section class="projects" id="projects">
  <div class="projects__inner">

    <header class="projects__header">
      <p class="section-label" data-reveal>Projets</p>
      <h2 class="section-title" data-reveal data-delay="1">
        Ce que j'ai <span>construit.</span>
      </h2>
      <p class="section-subtitle" data-reveal data-delay="2">
        Une sélection de projets perso et pro, du concept à la mise en prod.
      </p>
    </header>

    <div class="projects__grid">
      {
        l_projects.map((project, i) => (
          <article class="project-card" data-reveal data-delay={String(i + 1)}>
            <!-- Image -->
            <div class="project-card__img-wrap">
              <img
                src={project.imageUrl}
                alt={`Aperçu — ${project.title}`}
                class="project-card__img"
                loading="lazy"
              />
              <!-- Hover overlay with links -->
              <div class="project-card__overlay" aria-hidden="true">
                <div class="project-card__overlay-links">
                  {project.liveUrl && (
                    <a
                      href={project.liveUrl}
                      class="project-card__icon-btn"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Voir ${project.title} en ligne`}
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                    </a>
                  )}
                  {project.githubUrl && (
                    <a
                      href={project.githubUrl}
                      class="project-card__icon-btn"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Code source de ${project.title}`}
                    >
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>

            <!-- Content -->
            <div class="project-card__body">
              <div class="project-card__meta">
                <span class="project-card__num">0{i + 1}</span>
                <span class="project-card__category">{project.category}</span>
              </div>
              <h3 class="project-card__title">{project.title}</h3>
              <p class="project-card__desc">{project.description}</p>
              <div class="project-card__tags">
                {project.l_tags.map((tag) => (
                  <span class="project-card__tag">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="projects__footer" data-reveal>
      <p>Vous avez un projet en tête ?</p>
      <a href="#contact" class="btn-outline">
        Parlons-en
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .projects {
    padding: 8rem 2rem;
  }

  .projects__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects__header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  /* Grid */
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Card */
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out), border-color 0.3s var(--ease-out);
  }

  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-strong);
  }

  /* Image */
  .project-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-muted);
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }

  .project-card:hover .project-card__img {
    transform: scale(1.06);
  }

  /* Overlay with links */
  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(9,9,11,0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
  }

  .project-card:hover .project-card__overlay {
    opacity: 1;
  }

  .project-card__overlay-links {
    display: flex;
    gap: 0.75rem;
  }

  .project-card__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s var(--ease-out), transform 0.2s var(--ease-spring);
  }

  .project-card__icon-btn:hover {
    background: rgba(255,255,255,0.25);
    transform: scale(1.1);
  }

  .project-card__icon-btn svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  /* Card body */
  .project-card__body {
    padding: 1.5rem;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .project-card__num {
    font-size: 0.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .project-card__category {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    background: var(--bg-muted);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
  }

  .project-card__title {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }

  .project-card__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-card__tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-muted);
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
  }

  /* Footer */
  .projects__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .projects__footer p {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-light);
    border: 1px solid transparent;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background 0.2s var(--ease-out), border-color 0.2s, transform 0.2s var(--ease-out), color 0.2s;
  }

  .btn-outline svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s var(--ease-out);
  }

  .btn-outline:hover {
    background: var(--accent);
    color: #fff;
    transform: translateX(2px);
  }

  .btn-outline:hover svg { transform: translateX(3px); }

  /* Responsive */
  @media (max-width: 1024px) {
    .projects__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .projects { padding: 6rem 1.5rem; }
    .projects__grid { grid-template-columns: 1fr; }
    .projects__footer { flex-direction: column; gap: 1.25rem; text-align: center; }
  }
</style>
