---
import { contact } from "../data/contact";
---

<section class="contact" id="contact">
  <div class="contact__inner">

    <header class="contact__header">
      <p class="section-label" data-reveal>Contact</p>
      <h2 class="section-title" data-reveal data-delay="1">
        Travaillons <span>ensemble.</span>
      </h2>
      <p class="section-subtitle" data-reveal data-delay="2">
        Un projet, une question, une opportunité — je lis tout.
      </p>
    </header>

    <div class="contact__grid">

      <!-- Info card -->
      <div class="contact__info" data-reveal data-delay="1">
        <h3 class="contact__info-title">Restons en contact</h3>

        <div class="contact__links">
          <a href={`mailto:${contact.email}`} class="contact__link">
            <span class="contact__link-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <span class="contact__link-body">
              <span class="contact__link-label">Email</span>
              <span class="contact__link-value">{contact.email}</span>
            </span>
            <svg class="contact__link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>

          {
            contact.location && (
              <div class="contact__link contact__link--static">
                <span class="contact__link-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </span>
                <span class="contact__link-body">
                  <span class="contact__link-label">Localisation</span>
                  <span class="contact__link-value">{contact.location}</span>
                </span>
              </div>
            )
          }
        </div>

        <!-- Social links -->
        <div class="contact__socials">
          {
            contact.l_socials.map((social) => (
              <a
                href={social.url}
                class="contact__social"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.name}
                title={social.name}
              >
                <Fragment set:html={social.icon} />
                <span>{social.name}</span>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Contact form -->
      <form class="contact__form" id="contact-form" novalidate data-reveal data-delay="2">
        <div class="contact__form-row">
          <div class="contact__field">
            <label for="name" class="contact__field-label">Nom</label>
            <input
              type="text"
              id="name"
              name="name"
              class="contact__input"
              placeholder="Jean Dupont"
              required
              autocomplete="name"
            />
          </div>
          <div class="contact__field">
            <label for="email" class="contact__field-label">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="contact__input"
              placeholder="jean@exemple.com"
              required
              autocomplete="email"
            />
          </div>
        </div>

        <div class="contact__field">
          <label for="subject" class="contact__field-label">Sujet</label>
          <div class="contact__select-wrap">
            <select id="subject" name="subject" class="contact__input contact__select" required>
              <option value="" disabled selected>Choisir un sujet</option>
              <option value="projet">Nouveau projet</option>
              <option value="collaboration">Collaboration</option>
              <option value="emploi">Opportunité d'emploi</option>
              <option value="autre">Autre</option>
            </select>
            <svg class="contact__select-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>

        <div class="contact__field">
          <label for="message" class="contact__field-label">Message</label>
          <textarea
            id="message"
            name="message"
            class="contact__input contact__textarea"
            placeholder="Décrivez votre projet ou votre demande..."
            rows="5"
            required
          ></textarea>
        </div>

        <button type="submit" class="contact__submit" id="submit-btn">
          <span class="contact__submit-label">Envoyer le message</span>
          <svg class="contact__submit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </form>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    const label = submitBtn.querySelector(".contact__submit-label") as HTMLSpanElement | null;
    const icon = submitBtn.querySelector(".contact__submit-icon") as SVGElement | null;

    submitBtn.disabled = true;
    submitBtn.classList.add("contact__submit--loading");
    if (label) label.textContent = "Envoi en cours...";
    if (icon) icon.style.opacity = "0";

    // Fake send delay (replace with your actual API call)
    await new Promise((r) => setTimeout(r, 1500));

    submitBtn.classList.remove("contact__submit--loading");
    submitBtn.classList.add("contact__submit--success");
    if (label) label.textContent = "Message envoyé !";

    setTimeout(() => {
      if (!form || !submitBtn || !label || !icon) return;
      form.reset();
      submitBtn.disabled = false;
      submitBtn.classList.remove("contact__submit--success");
      label.textContent = "Envoyer le message";
      icon.style.opacity = "1";
    }, 3000);
  });
</script>

<style>
  .contact {
    padding: 8rem 2rem;
  }

  .contact__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact__header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  /* ─── Grid ───────────────────────── */

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ─── Info card ──────────────────── */

  .contact__info {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .contact__info-title {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .contact__links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background 0.2s var(--ease-out), border-color 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .contact__link:not(.contact__link--static):hover {
    background: var(--accent-light);
    border-color: var(--accent);
    transform: translateX(3px);
  }

  .contact__link--static {
    cursor: default;
  }

  .contact__link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--accent);
    border-radius: var(--radius);
    flex-shrink: 0;
    color: #fff;
  }

  .contact__link-icon svg {
    width: 1rem;
    height: 1rem;
  }

  .contact__link-body {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }

  .contact__link-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }

  .contact__link-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact__link-arrow {
    width: 1rem;
    height: 1rem;
    color: var(--text-faint);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s var(--ease-out);
    flex-shrink: 0;
  }

  .contact__link:not(.contact__link--static):hover .contact__link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Socials */
  .contact__socials {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .contact__social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius);
    transition: background 0.2s var(--ease-out), color 0.2s var(--ease-out);
  }

  .contact__social:hover {
    background: var(--bg-muted);
    color: var(--text);
  }

  .contact__social :global(svg) {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }

  /* ─── Form ───────────────────────── */

  .contact__form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact__field-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
  }

  .contact__input {
    padding: 0.8125rem 1rem;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--text);
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    outline: none;
    transition: border-color 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out), background 0.2s;
    width: 100%;
  }

  .contact__input::placeholder {
    color: var(--text-faint);
  }

  .contact__input:focus {
    background: var(--bg-card);
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
  }

  /* Custom select */
  .contact__select-wrap {
    position: relative;
  }

  .contact__select {
    appearance: none;
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .contact__select-icon {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    color: var(--text-faint);
    pointer-events: none;
  }

  .contact__textarea {
    resize: vertical;
    min-height: 130px;
    line-height: 1.6;
  }

  /* Submit button */
  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9375rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    color: #fff;
    background: var(--accent);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    margin-top: 0.25rem;
    box-shadow: 0 4px 16px var(--accent-glow);
    transition: background 0.2s var(--ease-out), transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
  }

  .contact__submit:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  .contact__submit:active {
    transform: translateY(0);
  }

  .contact__submit:disabled {
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .contact__submit-icon {
    width: 1rem;
    height: 1rem;
    transition: opacity 0.2s;
  }

  .contact__submit--loading {
    opacity: 0.75;
  }

  .contact__submit--success {
    background: #16a34a;
    box-shadow: 0 4px 16px rgba(22,163,74,0.25);
  }

  .contact__submit--success:hover {
    background: #15803d;
  }

  /* ─── Responsive ──────────────────── */

  @media (max-width: 900px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact { padding: 6rem 1.5rem; }

    .contact__form-row {
      grid-template-columns: 1fr;
    }

    .contact__info,
    .contact__form {
      padding: 1.5rem;
    }
  }
</style>
