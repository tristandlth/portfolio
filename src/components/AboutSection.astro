---
import { profile } from "../data/profile";
import { Icon } from "astro-icon/components";
---

<section class="about" id="about">
  <div class="about__inner">

    <!-- Left column: photo + card -->
    <div class="about__aside">
      <div class="about__photo-wrap" data-reveal>
        <img
          src={profile.photoUrl}
          alt={`Photo de ${profile.name}`}
          class="about__photo"
          loading="lazy"
        />
      </div>

      <div class="about__card" data-reveal data-delay="1">
        <p class="about__card-name">{profile.name}</p>
        <p class="about__card-role">{profile.title}</p>
        {
          profile.available && (
            <div class="about__card-status">
              <span class="about__status-dot" aria-hidden="true"></span>
              {profile.availableText}
            </div>
          )
        }
        <a href={profile.cvUrl} target="_blank" rel="noopener" class="about__cv-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Télécharger mon CV
        </a>
      </div>
    </div>

    <!-- Right column: text + stats + skills -->
    <div class="about__main">
      <header class="about__header">
        <p class="section-label" data-reveal>À propos</p>
        <h2 class="section-title" data-reveal data-delay="1">
          Des interfaces soignées,<br />
          <span>une stack solide.</span>
        </h2>
        <p class="section-subtitle about__bio" data-reveal data-delay="2">
          Développeur Full Stack basé à Toulouse, je travaille aussi bien sur
          le front-end que le back-end. J'aime construire des produits qui sont
          à la fois bien conçus et robustes.
        </p>
      </header>

      <!-- Stats row -->
      <div class="about__stats" data-reveal data-delay="3">
        {
          profile.l_stats.map((stat) => (
            <div class="about__stat">
              <span class="about__stat-value">{stat.value}</span>
              <span class="about__stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>

      <!-- Skills -->
      <div class="about__skills" data-reveal data-delay="4">
        <p class="about__skills-label">Technologies</p>
        <div class="about__skills-grid">
          {
            profile.l_skills.map((skill) => (
              <div class="about__skill">
                <Icon
                  name={skill.icon}
                  class="about__skill-icon"
                  style={{ color: skill.color }}
                  aria-hidden="true"
                />
                <span>{skill.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .about {
    padding: 8rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .about__inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ─── Left column ─────────────────── */

  .about__aside {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    position: sticky;
    top: 6rem;
  }

  .about__photo-wrap {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--border-strong);
    box-shadow: var(--shadow-lg), 0 0 0 6px var(--accent-light);
    transition: box-shadow 0.3s var(--ease-out);
  }

  .about__photo-wrap:hover {
    box-shadow: var(--shadow-lg), 0 0 0 8px var(--accent-light), 0 0 40px var(--accent-glow);
  }

  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }

  .about__photo-wrap:hover .about__photo {
    transform: scale(1.04);
  }

  .about__card {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .about__card-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .about__card-role {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .about__card-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #16a34a;
    background: rgba(22,163,74,0.08);
    border: 1px solid rgba(22,163,74,0.2);
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-full);
    margin-bottom: 1.25rem;
  }

  [data-theme="dark"] .about__card-status {
    color: #4ade80;
    background: rgba(74,222,128,0.08);
    border-color: rgba(74,222,128,0.2);
  }

  .about__status-dot {
    width: 6px;
    height: 6px;
    background: #16a34a;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  [data-theme="dark"] .about__status-dot { background: #4ade80; }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .about__cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--accent-light);
    border-radius: var(--radius-full);
    background: var(--accent-light);
    transition: background 0.2s var(--ease-out), border-color 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .about__cv-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: translateY(-1px);
  }

  .about__cv-btn svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  /* ─── Right column ─────────────────── */

  .about__main {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-top: 0.5rem;
  }

  .about__header { display: flex; flex-direction: column; gap: 0; }

  .about__bio {
    margin-top: 1.25rem;
  }

  /* Stats */
  .about__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .about__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .about__stat-value {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--text);
    line-height: 1;
  }

  .about__stat-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  /* Skills */
  .about__skills-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    margin-bottom: 0.875rem;
  }

  .about__skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .about__skill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s var(--ease-out), transform 0.2s var(--ease-spring), box-shadow 0.2s var(--ease-out);
  }

  .about__skill:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .about__skill-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* ─── Responsive ───────────────────── */

  @media (max-width: 900px) {
    .about__inner {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }

    .about__aside {
      position: static;
      flex-direction: row;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .about__photo-wrap {
      width: 150px;
      height: 150px;
    }

    .about__card {
      flex: 1;
      min-width: 200px;
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .about {
      padding: 6rem 1.5rem;
    }

    .about__aside {
      flex-direction: column;
      align-items: center;
    }

    .about__card { text-align: center; }

    .about__stats {
      grid-template-columns: 1fr;
    }

    .about__stat {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .about__stat-value { font-size: 1.75rem; }
  }
</style>
