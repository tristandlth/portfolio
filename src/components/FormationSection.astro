---
import { l_formations } from "../data/formation";
---

<section class="formation" id="formation">
  <div class="formation__inner">

    <header class="formation__header">
      <p class="section-label" data-reveal>Parcours</p>
      <h2 class="section-title" data-reveal data-delay="1">
        Ma <span>formation.</span>
      </h2>
      <p class="section-subtitle" data-reveal data-delay="2">
        Cursus académique et certifications professionnelles.
      </p>
    </header>

    <div class="timeline">
      {
        l_formations.map((item, i) => (
          <article class="timeline__item" data-reveal data-delay={String((i % 4) + 1)}>
            <!-- The dot + line on the left -->
            <div class="timeline__track" aria-hidden="true">
              <div class="timeline__dot"></div>
              {i < l_formations.length - 1 && <div class="timeline__line"></div>}
            </div>

            <!-- The card on the right -->
            <div class="timeline__card">
              <div class="timeline__card-top">
                <span class="timeline__date">{item.date}</span>
                {item.current && (
                  <span class="timeline__badge">En cours</span>
                )}
              </div>

              <h3 class="timeline__title">{item.title}</h3>
              <p class="timeline__school">{item.school}</p>

              {item.description && (
                <p class="timeline__desc">{item.description}</p>
              )}

              {item.l_skills && item.l_skills.length > 0 && (
                <div class="timeline__skills">
                  {item.l_skills.map((skill) => (
                    <span class="timeline__skill">{skill}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>

  </div>
</section>

<style>
  .formation {
    padding: 8rem 2rem;
    background: var(--bg-muted);
  }

  .formation__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .formation__header {
    margin-bottom: 4rem;
  }

  /* ─── Timeline ───────────────────────── */

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 1.25rem;
  }

  /* Track: dot + line */
  .timeline__track {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    padding-top: 1.625rem;
  }

  .timeline__dot {
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .timeline__line {
    width: 2px;
    flex: 1;
    margin-top: 6px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    min-height: 2rem;
  }

  /* Card */
  .timeline__card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .timeline__card:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow);
  }

  .timeline__card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .timeline__date {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .timeline__badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #16a34a;
    background: rgba(22,163,74,0.08);
    border: 1px solid rgba(22,163,74,0.2);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
  }

  [data-theme="dark"] .timeline__badge {
    color: #4ade80;
    background: rgba(74,222,128,0.08);
    border-color: rgba(74,222,128,0.2);
  }

  .timeline__title {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .timeline__school {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .timeline__desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .timeline__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .timeline__skill {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-muted);
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .formation { padding: 6rem 1.5rem; }

    .timeline__item {
      grid-template-columns: 20px 1fr;
      gap: 1rem;
    }

    .timeline__dot {
      width: 10px;
      height: 10px;
    }

    .timeline__card {
      padding: 1.25rem;
      margin-bottom: 1.25rem;
    }
  }
</style>
