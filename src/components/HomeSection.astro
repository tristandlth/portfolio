---
import { profile } from "../data/profile";
---

<section class="hero" id="home">
  <div class="hero__content">
    <div class="hero__badge" data-reveal>
      <span class="hero__badge-dot" aria-hidden="true"></span>
      {profile.availableText}
    </div>

    <h1 class="hero__name" data-reveal data-delay="1">
      {profile.name}
    </h1>

    <div class="hero__role-wrapper" data-reveal data-delay="2">
      <span class="hero__role" id="typed-text" aria-live="polite"></span>
      <span class="hero__cursor" aria-hidden="true"></span>
    </div>

    <p class="hero__desc" data-reveal data-delay="3">
      Je conçois et développe des applications web et mobile,<br />
      du back-end à l'interface.
    </p>

    <div class="hero__cta" data-reveal data-delay="4">
      <a href="#projects" class="btn btn--primary">
        Voir mes projets
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href={profile.cvUrl} target="_blank" rel="noopener" class="btn btn--ghost">
        Télécharger CV
      </a>
    </div>
  </div>

  <!-- Scroll down indicator -->
  <a href="#about" class="hero__scroll" aria-label="Défiler vers la section suivante">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"></line>
      <polyline points="19 12 12 19 5 12"></polyline>
    </svg>
  </a>
</section>

<script define:vars={{ l_roles: profile.l_roles }}>
  // Simple typewriter — types a word, pauses, deletes, moves on
  class TypeWriter {
    constructor(el, words) {
      this.el = el;
      this.words = words;
      this.wordIndex = 0;
      this.charIndex = 0;
      this.deleting = false;
    }

    tick() {
      const word = this.words[this.wordIndex];

      if (this.deleting) {
        this.charIndex--;
      } else {
        this.charIndex++;
      }

      this.el.textContent = word.substring(0, this.charIndex);

      let delay = this.deleting ? 35 : 75;

      if (!this.deleting && this.charIndex === word.length) {
        delay = 2200;
        this.deleting = true;
      } else if (this.deleting && this.charIndex === 0) {
        this.deleting = false;
        this.wordIndex = (this.wordIndex + 1) % this.words.length;
        delay = 400;
      }

      setTimeout(() => this.tick(), delay);
    }
  }

  const el = document.getElementById("typed-text");
  if (el) {
    const tw = new TypeWriter(el, l_roles);
    // Small delay so page has settled before typing starts
    setTimeout(() => tw.tick(), 800);
  }
</script>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem 4rem;
    text-align: center;
    position: relative;
  }

  .hero__content {
    max-width: 720px;
    width: 100%;
  }

  /* Available badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #16a34a;
    background: rgba(22,163,74,0.08);
    border: 1px solid rgba(22,163,74,0.2);
    border-radius: var(--radius-full);
    margin-bottom: 2rem;
  }

  [data-theme="dark"] .hero__badge {
    color: #4ade80;
    background: rgba(74,222,128,0.08);
    border-color: rgba(74,222,128,0.2);
  }

  .hero__badge-dot {
    width: 7px;
    height: 7px;
    background: #16a34a;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  [data-theme="dark"] .hero__badge-dot {
    background: #4ade80;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  /* Name */
  .hero__name {
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.95;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  /* Typing role */
  .hero__role-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    margin-bottom: 1.75rem;
  }

  .hero__role {
    font-size: clamp(1.125rem, 3vw, 1.5rem);
    font-weight: 600;
    color: var(--accent);
    letter-spacing: -0.02em;
    min-width: 1px;
  }

  .hero__cursor {
    display: inline-block;
    width: 2px;
    height: 1.5em;
    background: var(--accent);
    margin-left: 3px;
    border-radius: 1px;
    animation: blink 1s step-end infinite;
    vertical-align: middle;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Description */
  .hero__desc {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  /* CTAs */
  .hero__cta {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.625rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: inherit;
    border-radius: var(--radius-full);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.2s var(--ease-out), transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out), color 0.2s var(--ease-out);
  }

  .btn svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s var(--ease-out);
  }

  .btn:hover svg { transform: translateX(3px); }

  .btn--primary {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 4px 16px var(--accent-glow);
  }

  .btn--primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  .btn--primary:active { transform: translateY(0); }

  .btn--ghost {
    background: var(--bg-muted);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .btn--ghost:hover {
    background: var(--border);
    color: var(--text);
  }

  /* Scroll arrow */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--text-faint);
    text-decoration: none;
    animation: bounce 2s ease-in-out infinite;
    transition: color 0.2s var(--ease-out);
  }

  .hero__scroll:hover { color: var(--accent); }

  .hero__scroll svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 640px) {
    .hero__desc br { display: none; }
    .hero__scroll { bottom: 1.5rem; }
  }
</style>
